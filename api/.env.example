# Copy this file to .env and fill in your values.
# In production, all values with <CHANGE_ME> must be overridden.

ENVIRONMENT=development
DEBUG=true

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<CHANGE_ME_generate_a_random_secret_key>

# Database connection (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://aiwf:<CHANGE_ME_db_password>@localhost:5432/aiwf_dev

# Redis connection (requires password)
REDIS_URL=redis://:<CHANGE_ME_redis_password>@localhost:6379/0

# Open Policy Agent URL
OPA_URL=http://localhost:8181

# Observability (optional in development)
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# MCP Server toggles
MCP_POSTGRES_ENABLED=true
MCP_GITHUB_ENABLED=false
MCP_PUPPETEER_ENABLED=false
MCP_SLACK_ENABLED=false
